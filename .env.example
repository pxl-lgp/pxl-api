# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000,https://pxl-lgp.vercel.app

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pxl_automation

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# AI
AI_PROVIDER=groq
AI_MODEL=
GROQ_API_KEY=
OPENAI_API_KEY=

# Meta publishing
META_GRAPH_API_VERSION=v25.0
META_APP_ID=
META_APP_SECRET=
META_LOGIN_CONFIG_ID=
META_OAUTH_REDIRECT_URI=http://localhost:4000/api/social-connections/meta/callback
FRONTEND_URL=http://localhost:3000
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SOCIAL_TOKEN_ENCRYPTION_KEY=

# Automation
N8N_WEBHOOK_BASE_URL=
N8N_CLIENT_CREATED_WEBHOOK_URL=
N8N_CONTENT_SCHEDULED_WEBHOOK_URL=
N8N_LEAD_CREATED_WEBHOOK_URL=
AUTOMATION_WEBHOOK_SECRET=

# Google Drive service account
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=

# Google Drive OAuth (recommended for a personal My Drive account)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# Local admin seed
SEED_ADMIN_EMAIL=admin@pxl.local
SEED_ADMIN_NAME=PXL Admin
SEED_ADMIN_PASSWORD=change-this-password
