# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000,https://pxl-lgp.vercel.app

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pxl_automation

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# AI
AI_PROVIDER=groq
AI_MODEL=
GROQ_API_KEY=
OPENAI_API_KEY=

# Meta publishing
META_GRAPH_API_VERSION=v25.0
META_APP_ID=
META_APP_SECRET=
META_LOGIN_CONFIG_ID=
META_OAUTH_REDIRECT_URI=http://localhost:4000/api/social-connections/meta/callback
FRONTEND_URL=http://localhost:3000
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SOCIAL_TOKEN_ENCRYPTION_KEY=

# Google Drive — ID of the folder where client folders are auto-created on signup
DRIVE_CLIENTS_PARENT_FOLDER_ID=

# SMTP — for team email notifications (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PXL <noreply@pxl.local>
TEAM_NOTIFICATION_EMAIL=

# Google Drive service account
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=

# Google Drive OAuth (recommended for a personal My Drive account)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# Google Calendar — calendar that receives content publishing reminders on schedule.
# Reuses the Google Drive OAuth/service-account credentials above, so reminders are
# active whenever those credentials are set AND also have calendar access. Defaults
# to the authorized account's "primary" calendar; set an ID to target another.
GOOGLE_CALENDAR_ID=

# Local admin seed
SEED_ADMIN_EMAIL=admin@pxl.local
SEED_ADMIN_NAME=PXL Admin
SEED_ADMIN_PASSWORD=change-this-password
