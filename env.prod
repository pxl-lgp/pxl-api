# Production environment guide for pxl-api.
# Do not paste local development secrets here. Use this as the checklist for your
# hosting provider's environment variable dashboard, or copy it to .env on the
# production server and fill in real values there.

# Server
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://your-production-frontend-domain.com
FRONTEND_URL=https://your-production-frontend-domain.com

# Database
# Use your production PostgreSQL URL. If your host currently uses sslmode=require,
# prefer sslmode=verify-full when supported to avoid pg SSL warnings.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full

# Auth
# Generate a long random value, at least 32 bytes.
# Example: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=replace-with-production-random-secret
JWT_EXPIRES_IN=7d

# AI
# Set AI_PROVIDER to groq or openai, then provide the matching API key.
AI_PROVIDER=groq
AI_MODEL=
GROQ_API_KEY=
OPENAI_API_KEY=

# Meta publishing / OAuth
META_GRAPH_API_VERSION=v25.0
META_APP_ID=
META_APP_SECRET=
META_LOGIN_CONFIG_ID=
META_OAUTH_REDIRECT_URI=https://your-production-api-domain.com/api/social-connections/meta/callback

# Social token encryption
# Must be stable across deployments. Do not rotate unless you are ready to
# invalidate/re-encrypt existing social connection tokens.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SOCIAL_TOKEN_ENCRYPTION_KEY=

# Google Drive / Calendar
# DRIVE_CLIENTS_PARENT_FOLDER_ID takes precedence. GOOGLE_DRIVE_CLIENTS_PARENT_FOLDER_ID
# falls back to root if omitted.
DRIVE_CLIENTS_PARENT_FOLDER_ID=
GOOGLE_DRIVE_CLIENTS_PARENT_FOLDER_ID=
GOOGLE_CALENDAR_ID=primary

# Google Drive OAuth, recommended for a personal My Drive account
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# Google Drive service account alternative
# If using this, keep GOOGLE_DRIVE_PRIVATE_KEY quoted in your hosting dashboard
# or encode newlines as \n.
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=

# SMTP notifications, optional. Leave blank to disable email notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PXL <noreply@your-domain.com>
TEAM_NOTIFICATION_EMAIL=

# One-time admin seed values. Only needed when running pnpm seed:admin in prod.
SEED_ADMIN_EMAIL=admin@your-domain.com
SEED_ADMIN_NAME=PXL Admin
SEED_ADMIN_PASSWORD=replace-with-strong-admin-password
